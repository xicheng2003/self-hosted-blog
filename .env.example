# Database
DATABASE_URL="postgresql://user:password@host:5432/database"
DIRECT_URL="postgresql://user:password@host:5432/database"

# MinIO S3 API
# Use the MinIO S3 API endpoint here, not the public asset domain.
S3_ENDPOINT="http://127.0.0.1:9000"
S3_ACCESS_KEY_ID="your-minio-access-key"
S3_SECRET_ACCESS_KEY="your-minio-secret-key"
S3_BUCKET_NAME="blog-images"
S3_REGION="us-east-1"

# Public asset domain routed to the same MinIO bucket.
# This is the domain that appears in article content and direct links.
S3_PUBLIC_DOMAIN="https://oss.example.com"

# Auth
AUTH_SECRET="replace-with-a-random-secret"
